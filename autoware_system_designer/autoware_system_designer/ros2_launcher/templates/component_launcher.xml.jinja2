<?xml version="1.0"?>
<launch>
  <!-- This launch file is auto-generated by the autoware_system_designer -->
  <!-- Component Launcher: {{ namespace }} -->
  <!-- Compute Unit: {{ compute_unit }} -->
  <!-- This launcher starts all nodes in component: {{ namespace }} -->

{% for arg_name in forward_args %}
  <arg name="{{ arg_name }}"/>
{% endfor %}
{% macro node_configuration(node) %}
<!-- Remap input and output topics -->
{% for port in node.ports %}
<remap from="{{ port.remap_target }}" to="{{ port.topic }}"/>
{% endfor %}

<!-- Parameters - Non-Override Parameters -->
{% for param in node.param_values %}
{% if param.parameter_type != 'OVERRIDE' and param.parameter_type != 'OVERRIDE_FILE' and param.parameter_type != 'MODE' and param.parameter_type != 'MODE_FILE' %}
<param name="{{ param.name }}" value="{{ param.value }}"/>
{% endif %}
{% endfor %}

<!-- Parameters - Override Parameter files -->
{% for param_file in node.param_files %}
{% if param_file.parameter_type == 'OVERRIDE_FILE' %}
<param from="{{ param_file.path }}" allow_substs="{{ param_file.allow_substs }}"/>
{% endif %}
{% endfor %}

<!-- Parameters - Mode Parameter files -->
{% for param_file in node.param_files %}
{% if param_file.parameter_type == 'MODE_FILE' %}
<param from="{{ param_file.path }}" allow_substs="{{ param_file.allow_substs }}"/>
{% endif %}
{% endfor %}

<!-- Parameters - Overrides -->
{% for param in node.param_values %}
{% if param.parameter_type == 'OVERRIDE' %}
<param name="{{ param.name }}" value="{{ param.value }}"/>
{% endif %}
{% endfor %}

<!-- Parameters - Mode Overrides (highest priority) -->
{% for param in node.param_values %}
{% if param.parameter_type == 'MODE' %}
<param name="{{ param.name }}" value="{{ param.value }}"/>
{% endif %}
{% endfor %}
{% endmacro %}

{% for node in nodes %}
  <!-- Node: {{ node.full_namespace_path }}/{{ node.name }} -->
{% if node.launch_state == 'ros2_launch_file' %}
  <include file="$(find-pkg-share {{node.package}})/launch/{{node.ros2_launch_file}}">
{% for param_file in node.param_files %}
    <arg name="{{ param_file.name }}" value="{{ param_file.path }}"/>
{% endfor %}
{% for param in node.param_values %}
{% if param.parameter_type == 'DEFAULT' or param.parameter_type == 'DEFAULT_FILE' %}
{% if param.name in forward_args %}
    <arg name="{{ param.name }}" value="$(var {{ param.name }})"/>
{% else %}
    <arg name="{{ param.name }}" value="{{ param.value }}"/>
{% endif %}
{% endif %}
{% endfor %}
{% for param in node.param_values %}
{% if param.parameter_type == 'MODE' %}
{% if param.name in forward_args %}
    <arg name="{{ param.name }}" value="$(var {{ param.name }})"/>
{% else %}
    <arg name="{{ param.name }}" value="{{ param.value }}"/>
{% endif %}
{% endif %}
{% endfor %}
{% for param in node.param_values %}
{% if param.parameter_type == 'OVERRIDE' %}
{% if param.name in forward_args %}
    <arg name="{{ param.name }}" value="$(var {{ param.name }})"/>
{% else %}
    <arg name="{{ param.name }}" value="{{ param.value }}"/>
{% endif %}
{% endif %}
{% endfor %}
  </include>
{% elif node.launch_state == 'composable_node' %}
  <load_composable_node target="{{ node.container_target }}">
    <composable_node pkg="{{ node.package }}" plugin="{{ node.plugin }}" name="{{ node.name }}" namespace="{{ node.full_namespace_path }}">
      {{ node_configuration(node)|indent(6) }}
    </composable_node>
  </load_composable_node>
{% elif node.launch_state == 'node_container' %}
  <node_container pkg="{{ node.package }}" exec="{{ node.executable }}" name="{{ node.name }}" namespace="{{ node.full_namespace_path }}" output="{{ node.node_output }}">
    <composable_node pkg="autoware_glog_component" plugin="autoware::glog_component::GlogComponent" name="glog_component" namespace=""/>
  </node_container>
{% else %}
  <node pkg="{{ node.package }}" exec="{{ node.executable }}" name="{{ node.name }}" namespace="{{ node.full_namespace_path }}" output="{{ node.node_output }}"{% if node.args %} args="{{ node.args }}"{% endif %}>
    {{ node_configuration(node)|indent(4) }}
  </node>
{% endif %}

{% endfor %}
</launch>
